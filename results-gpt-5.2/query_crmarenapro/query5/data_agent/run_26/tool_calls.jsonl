'order_item_id_norm'].isin(order_items_for_product)].copy()\n\n# count issues\ncounts = df_cp.groupby('issue_id').size().sort_values(ascending=False)\nissue_id = counts.index[0] if len(counts)>0 else None\n\nprint('__RESULT__:')\nprint(json.dumps({'issue_id': issue_id}))", "env": {"var_call_pvH5Ckx5mCOMC8HLFY7vz2Ra": "file_storage/call_pvH5Ckx5mCOMC8HLFY7vz2Ra.json", "var_call_t7rZuIs9isALY344MuH26Ivy": [{"issue_id": "a03Wt00000JqzSfIAJ", "order_item_id": "802Wt00000797r4IAA", "createddate": "2023-07-02T11:00:00.000+0000"}, {"issue_id": "a03Wt00000JqtOtIAJ", "order_item_id": "802Wt00000792tiIAA", "createddate": "2023-09-30T11:30:00.000+0000"}, {"issue_id": "a03Wt00000JqtOtIAJ", "order_item_id": "802Wt00000792tiIAA", "createddate": "2023-10-02T14:15:00.000+0000"}, {"issue_id": "a03Wt00000JqmX6IAJ", "order_item_id": "802Wt00000794bXIAQ", "createddate": "2023-04-05T17:51:00.000+0000"}, {"issue_id": "a03Wt00000JqxtvIAB", "order_item_id": "802Wt00000796yFIAQ", "createddate": "2023-03-08T06:49:00.000+0000"}, {"issue_id": "a03Wt00000JqzPSIAZ", "order_item_id": "802Wt0000079ATxIAM", "createddate": "2023-08-15T14:30:00.000+0000"}, {"issue_id": "a03Wt00000JqzUHIAZ", "order_item_id": "802Wt00000799EZIAY", "createddate": "2023-10-15T09:15:47.000+0000"}, {"issue_id": "a03Wt00000JqzPSIAZ", "order_item_id": "802Wt0000079ATxIAM", "createddate": "2023-10-02T09:15:00.000+0000"}, {"issue_id": "a03Wt00000JqmX6IAJ", "order_item_id": "802Wt00000790mNIAQ", "createddate": "2022-09-05T11:15:00.000+0000"}, {"issue_id": "a03Wt00000JqzKcIAJ", "order_item_id": "802Wt00000797RHIAY", "createddate": "2023-10-02T10:15:00.000+0000"}, {"issue_id": "a03Wt00000JqzR3IAJ", "order_item_id": "802Wt00000791h9IAA", "createddate": "2023-01-18T14:45:00.000+0000"}, {"issue_id": "a03Wt00000JqzPSIAZ", "order_item_id": "802Wt00000799mPIAQ", "createddate": "2023-01-04T08:47:00.000+0000"}, {"issue_id": "a03Wt00000JqzSfIAJ", "order_item_id": "802Wt000007906kIAA", "createddate": "2023-07-01T10:30:00.000+0000"}, {"issu
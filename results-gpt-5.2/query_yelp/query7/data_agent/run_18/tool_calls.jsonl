rom_2016_users AS (\n  SELECT r.business_ref\n  FROM review r\n  JOIN users_2016 u ON u.user_id = r.user_id\n  WHERE substr(r.date, 1, 4) >= '2016'\n)\nSELECT business_ref, COUNT(*) AS review_count\nFROM reviews_from_2016_users\nGROUP BY business_ref;"}, "val_args": {"db_type": "duckdb", "exec_args": {"db_path": "/home/ruiying/DataAgentBench/query_yelp/query_dataset/yelp_user.db", "sql": "WITH users_2016 AS (\n  SELECT user_id\n  FROM user\n  WHERE substr(yelping_since, 1, 4) = '2016'\n), reviews_from_2016_users AS (\n  SELECT r.business_ref\n  FROM review r\n  JOIN users_2016 u ON u.user_id = r.user_id\n  WHERE substr(r.date, 1, 4) >= '2016'\n)\nSELECT business_ref, COUNT(*) AS review_count\nFROM reviews_from_2016_users\nGROUP BY business_ref;"}}}
